
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🏢 Modelo: Condomínio (Cliente da sua cliente)
model Condominio {
  id                     Int                @id @default(autoincrement())
  nome                   String             // Ex: Residencial Dom Bosco
  cnpj                   String             @unique // Ex: 10.789.211/0001-09
  endereco               String?            // Av. Mário de Andrade, 979
  percentualGarantidora  Decimal            @default(4.00) @db.Decimal(5, 2)
  bancoInfo              Json?              // Ag: 4277, CC: 18.579-5
  honorarioMensal        Decimal            @db.Decimal(10, 2)
  
  // Relações
  unidades               Unidade[]
  despesas               Despesa[]
  taxasExtras            TaxaExtra[]
  cobrancasRecorrentes   CobrancaRecorrente[]
  fechamentos            FechamentoMensal[]
  usuarios               Usuario[]          // Usuários vinculados ao condomínio
  createdAt              DateTime           @default(now())
}

// 🔐 Modelo: Usuário e Controle de Acesso
model Usuario {
  id            Int         @id @default(autoincrement())
  nome          String
  email         String      @unique
  senha         String
  role          Role        @default(AUXILIAR)
  status        Boolean     @default(true)
  
  condominioId  Int?        // Null se for ADMIN_MASTER
  condominio    Condominio? @relation(fields: [condominioId], references: [id])
  
  createdAt     DateTime    @default(now())
}

enum Role {
  ADMIN_MASTER
  SINDICO
  AUXILIAR
}

// 👥 Modelo: Unidade (Apartamentos)
model Unidade {
  id               Int        @id @default(autoincrement())
  numeroUnidade    String     // Ex: 0101
  nomeSacado       String     // Ex: Ingrid Pavani Ribeiro
  email            String?    // Para envio automático
  telefone         String?    
  
  condominioId     Int
  condominio       Condominio @relation(fields: [condominioId], references: [id])
  
  cobrancas        Cobranca[]
}

// 💰 Modelo: Cobrança Mensal (Receita - DRE Entrada)
model Cobranca {
  id              Int      @id @default(autoincrement())
  mesReferencia   String   // Ex: "05/2026"
  dataVencimento  DateTime
  valorCondominio Decimal  @db.Decimal(10, 2)
  valorTaxaExtra  Decimal  @db.Decimal(10, 2)
  totalBruto      Decimal  @db.Decimal(10, 2)
  status          Status   @default(PENDENTE)
  
  // Informações de Pagamento
  pixCopiaECola   String?
  linkPagamento   String?
  dataPagamento   DateTime?

  unidadeId       Int
  unidade         Unidade  @relation(fields: [unidadeId], references: [id])
}

enum Status {
  PENDENTE
  PAGO
  ATRASADO
  ACORDO
  VENCIDO
}

// 💸 Modelo: Despesa (Saída - DRE Saída)
model Despesa {
  id             Int               @id @default(autoincrement())
  dataPagamento  DateTime   
  descricao      String     
  valor          Decimal           @db.Decimal(10, 2)
  categoria      CategoriaDespesa  @default(OUTROS)
  comprovanteUrl String?
  
  condominioId   Int
  condominio     Condominio        @relation(fields: [condominioId], references: [id])
}

enum CategoriaDespesa {
  MANUTENCAO
  PESSOAL
  UTILIDADES
  ADMINISTRATIVO
  EXTRAORDINARIA
  OUTROS
}

// 📋 Modelo: Fechamento Mensal (Histórico do Balancete)
model FechamentoMensal {
  id                    Int        @id @default(autoincrement())
  mesReferencia         String     // Ex: "04/2026"[cite: 3]
  totalArrecadadoBruto  Decimal    @db.Decimal(12, 2) // R$ 62.363,52[cite: 1]
  custoGarantidora      Decimal    @db.Decimal(10, 2) // R$ 2.494,54[cite: 1]
  totalDespesas         Decimal    @db.Decimal(12, 2) // R$ 42.015,52[cite: 3]
  saldoFinalCaixa       Decimal    @db.Decimal(12, 2) // R$ 90.655,29[cite: 3]
  
  condominioId          Int
  condominio            Condominio @relation(fields: [condominioId], references: [id])
}

// 📋 Cobrança Recorrente (valores fixos mensais configurados por condomínio)
model CobrancaRecorrente {
  id           Int        @id @default(autoincrement())
  descricao    String     // Ex: "Portaria e Segurança", "CPFL - Energia"
  valor        Decimal    @db.Decimal(10, 2) // Valor mensal esperado
  ativo        Boolean    @default(true)
  condominioId Int
  condominio   Condominio @relation(fields: [condominioId], references: [id])
  createdAt    DateTime   @default(now())
}

// 🛠️ Modelo: Taxa Extra (Controle de Parcelas)
model TaxaExtra {
  id              Int        @id @default(autoincrement())
  nomeProjeto     String     // Ex: "Pintura"
  parcelaAtual    Int        // Ex: 25
  totalParcelas   Int        // Ex: 62
  valorParcela    Decimal    @db.Decimal(10, 2)
  ativo           Boolean    @default(true)
  
  condominioId    Int
  condominio      Condominio @relation(fields: [condominioId], references: [id])
  createdAt       DateTime   @default(now())
}