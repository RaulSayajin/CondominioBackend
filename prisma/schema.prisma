generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Condominio {
  id                    Int                  @id @default(autoincrement())
  nome                  String
  cnpj                  String               @unique
  endereco              String?
  percentualGarantidora Decimal              @default(4.00) @db.Decimal(5, 2)
  bancoInfo             Json?
  honorarioMensal       Decimal              @db.Decimal(10, 2)
  createdAt             DateTime             @default(now())
  cobrancasRecorrentes  CobrancaRecorrente[]
  despesas              Despesa[]
  fechamentos           FechamentoMensal[]
  taxasExtras           TaxaExtra[]
  unidades              Unidade[]
}

model Unidade {
  id            Int        @id @default(autoincrement())
  numeroUnidade String
  nomeSacado    String
  condominioId  Int
  cobrancas     Cobranca[]
  condominio    Condominio @relation(fields: [condominioId], references: [id])
}

model Cobranca {
  id              Int     @id @default(autoincrement())
  mesReferencia   String
  valorCondominio Decimal @db.Decimal(10, 2)
  valorTaxaExtra  Decimal @db.Decimal(10, 2)
  totalBruto      Decimal @db.Decimal(10, 2)
  status          Status  @default(PENDENTE)
  unidadeId       Int
  unidade         Unidade @relation(fields: [unidadeId], references: [id])
}

model Despesa {
  id             Int        @id @default(autoincrement())
  dataPagamento  DateTime
  descricao      String
  valor          Decimal    @db.Decimal(10, 2)
  comprovanteUrl String?
  condominioId   Int
  condominio     Condominio @relation(fields: [condominioId], references: [id])
}

model FechamentoMensal {
  id                   Int        @id @default(autoincrement())
  mesReferencia        String
  totalArrecadadoBruto Decimal    @db.Decimal(12, 2)
  custoGarantidora     Decimal    @db.Decimal(10, 2)
  totalDespesas        Decimal    @db.Decimal(12, 2)
  saldoFinalCaixa      Decimal    @db.Decimal(12, 2)
  condominioId         Int
  condominio           Condominio @relation(fields: [condominioId], references: [id])
}

model CobrancaRecorrente {
  id           Int        @id @default(autoincrement())
  descricao    String
  valor        Decimal    @db.Decimal(10, 2)
  ativo        Boolean    @default(true)
  condominioId Int
  createdAt    DateTime   @default(now())
  condominio   Condominio @relation(fields: [condominioId], references: [id])
}

model TaxaExtra {
  id               Int        @id @default(autoincrement())
  nomeProjeto      String
  parcelaAtual     Int
  totalParcelas    Int
  condominioId     Int
  valorMensalTotal Decimal    @default(0) @db.Decimal(10, 2)
  condominio       Condominio @relation(fields: [condominioId], references: [id])
}

enum Status {
  PENDENTE
  PAGO
  ATRASADO
  VENCIDO
}
